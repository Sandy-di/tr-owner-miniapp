/* pages/finance/list/list.wxss - 财务列表 v3.0 · Stripe */
.page-finance-list {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: 40rpx;
}

.finance-header {
  position: relative;
}

.finance-bg {
  height: 240rpx;
  background: linear-gradient(155deg, var(--brand-dark) 0%, #2a2d7a 40%, #3d40a8 100%);
}

.finance-summary {
  display: flex;
  align-items: center;
  margin: -140rpx 24rpx 0;
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  padding: 36rpx 24rpx;
  box-shadow: var(--shadow-card-hover);
  border: 1rpx solid var(--border-light);
  position: relative;
  z-index: 1;
}

.summary-item {
  flex: 1;
  text-align: center;
}

.summary-label {
  font-size: 22rpx;
  color: var(--body);
  display: block;
  margin-bottom: 10rpx;
  font-weight: 400;
}

.summary-amount {
  font-size: 28rpx;
  font-weight: 300;
  color: var(--heading);
  display: block;
  font-variant-numeric: tabular-nums;
  letter-spacing: -0.5rpx;
}

.summary-amount.income {
  color: var(--danger);
}

.summary-amount.expense {
  color: var(--success);
}

.summary-divider {
  width: 1rpx;
  height: 60rpx;
  background: var(--border-light);
}

.finance-list {

}

.finance-card {
  transition: transform var(--transition-fast);
}

.finance-card:active {
  transform: scale(0.992);
}

.finance-header-row {
  margin-bottom: 16rpx;
}

.finance-type {
  align-items: center;
  gap: 10rpx;
}

.type-icon {
  font-size: 28rpx;
}

.type-label {
  font-size: 24rpx;
  color: var(--body);
  font-weight: 400;
}

.finance-amount {
  font-size: 34rpx;
  font-weight: 300;
  font-variant-numeric: tabular-nums;
  letter-spacing: -1rpx;
}

.finance-amount.income {
  color: var(--danger);
}

.finance-amount.expense {
  color: var(--success);
}

.finance-title {
  font-size: 28rpx;
  color: var(--heading);
  font-weight: 500;
  display: block;
}

.finance-footer {

}

.approval-status {
  align-items: center;
  gap: 8rpx;
}

.approval-icon {
  font-size: 22rpx;
}

.approval-text {
  font-size: 22rpx;
  color: var(--body);
  font-weight: 400;
}

.finance-date {
  font-size: 22rpx;
  color: var(--body);
  font-variant-numeric: tabular-nums;
}
