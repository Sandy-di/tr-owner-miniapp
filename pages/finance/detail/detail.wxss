/* pages/finance/detail/detail.wxss - 财务详情 v3.0 · Stripe */
.page-finance-detail {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: 60rpx;
}

.amount-header {
  padding: 48rpx 28rpx;
}

.amount-type {
  font-size: 28rpx;
  color: var(--body);
  display: block;
  margin-bottom: 12rpx;
  font-weight: 400;
}

.amount-value {
  font-size: 64rpx;
  font-weight: 300;
  display: block;
  margin-bottom: 12rpx;
  letter-spacing: -2rpx;
  font-variant-numeric: tabular-nums;
}

.amount-value.income {
  color: var(--danger);
}

.amount-value.expense {
  color: var(--success);
}

.amount-title {
  font-size: 30rpx;
  color: var(--heading);
  display: block;
  font-weight: 500;
}

/* 审批联署 */
.approval-list {

}

.approval-item {
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border-light);
}

.approval-item:last-child {
  border-bottom: none;
}

.approval-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: var(--radius-md);
  background: rgba(83, 58, 253, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  font-size: 24rpx;
  color: var(--primary);
  font-weight: 500;
}

.approval-name {
  font-size: 28rpx;
  color: var(--heading);
  font-weight: 400;
}

.approval-status {
  font-size: 24rpx;
  color: var(--success);
  font-weight: 500;
}

/* 凭证 */
.voucher-list {

}

.voucher-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border-light);
  transition: background var(--transition-fast);
}

.voucher-item:last-child {
  border-bottom: none;
}

.voucher-item:active {
  background: var(--bg-hover);
}

.voucher-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.voucher-name {
  font-size: 26rpx;
  color: var(--heading);
  font-weight: 400;
}

.voucher-action {
  font-size: 24rpx;
  color: var(--primary);
  font-weight: 400;
}

.info-value.hash {
  font-family: 'SF Mono', 'Menlo', monospace;
  color: var(--primary);
  font-weight: 500;
}
