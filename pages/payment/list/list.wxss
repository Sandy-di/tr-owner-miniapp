/* pages/payment/list/list.wxss - 缴费列表 v3.0 · Stripe */
.page-payment-list {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: 40rpx;
}

.summary-header {
  position: relative;
  padding: 0 24rpx;
}

.summary-bg {
  height: 280rpx;
  background: linear-gradient(155deg, var(--brand-dark) 0%, #2a2d7a 40%, #3d40a8 100%);
  border-radius: 0 0 var(--radius-xl) var(--radius-xl);
}

.summary-content {
  position: relative;
  z-index: 1;
  margin-top: -200rpx;
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  padding: 40rpx;
  box-shadow: var(--shadow-card-hover);
  border: 1rpx solid var(--border-light);
  text-align: center;
}

.summary-label {
  font-size: 26rpx;
  color: var(--body);
  display: block;
  margin-bottom: 12rpx;
  font-weight: 400;
}

.summary-amount {
  font-size: 64rpx;
  font-weight: 300;
  color: var(--danger);
  display: block;
  margin-bottom: 28rpx;
  letter-spacing: -2rpx;
  font-variant-numeric: tabular-nums;
}

.pay-all-btn {
  display: inline-flex;
  align-items: center;
  background: var(--primary);
  color: #FFFFFF;
  border-radius: var(--radius-sm);
  padding: 18rpx 64rpx;
  font-size: 28rpx;
  font-weight: 500;
  transition: all var(--transition-fast);
}

.pay-all-btn:active {
  background: var(--primary-hover);
  transform: translateY(2rpx);
}

.payment-list {
  margin-top: 20rpx;
}

.payment-card {
  transition: transform var(--transition-fast);
}

.payment-card:active {
  transform: scale(0.992);
}

.payment-header {
  margin-bottom: 16rpx;
}

.payment-type-icon {
  font-size: 36rpx;
}

.payment-title {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--heading);
  display: block;
  letter-spacing: -0.2rpx;
}

.payment-period {
  font-size: 24rpx;
  color: var(--body);
  font-weight: 400;
}

.payment-amount {
  font-size: 34rpx;
  font-weight: 300;
  color: var(--heading);
  font-variant-numeric: tabular-nums;
  letter-spacing: -1rpx;
}

.payment-footer {

}

.payment-due {
  font-size: 22rpx;
  color: var(--body);
  font-weight: 400;
}

.pay-btn {
  font-size: 24rpx;
  color: #FFFFFF;
  background: var(--primary);
  padding: 10rpx 28rpx;
  border-radius: var(--radius-xs);
  font-weight: 500;
  transition: all var(--transition-fast);
}

.pay-btn:active {
  background: var(--primary-hover);
}

.receipt-btn {
  font-size: 24rpx;
  color: var(--primary);
  padding: 10rpx 28rpx;
  border: 2rpx solid var(--border-purple);
  border-radius: var(--radius-xs);
  font-weight: 400;
}
