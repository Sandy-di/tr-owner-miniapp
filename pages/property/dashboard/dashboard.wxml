<!--pages/property/dashboard/dashboard.wxml-->
<view class="page-property-dashboard">
  <!-- 看板统计 -->
  <view class="dashboard-header">
    <view class="dashboard-bg"></view>
    <view class="stats-grid">
      <view class="stat-item">
        <text class="stat-num warning">{{stats.submitted}}</text>
        <text class="stat-label">待接单</text>
      </view>
      <view class="stat-item">
        <text class="stat-num primary">{{stats.accepted}}</text>
        <text class="stat-label">已接单</text>
      </view>
      <view class="stat-item">
        <text class="stat-num primary">{{stats.processing}}</text>
        <text class="stat-label">处理中</text>
      </view>
      <view class="stat-item">
        <text class="stat-num warning">{{stats.pending_check}}</text>
        <text class="stat-label">待验收</text>
      </view>
    </view>
  </view>

  <!-- SLA 超时警告 -->
  <view class="sla-banner" wx:if="{{stats.sla_exceeded > 0}}" bindtap="onRefresh">
    <image class="sla-icon" src="{{icons.warningRed}}" mode="aspectFit" />
    <text class="sla-text">{{stats.sla_exceeded}} 个工单已超过 SLA 时限，请立即处理！</text>
    <text class="sla-action">查看 ›</text>
  </view>

  <!-- 操作栏 -->
  <view class="action-bar flex-between container">
    <view class="section-title" style="margin-bottom:0">
      <image class="icon" src="{{icons.clipboard}}" mode="aspectFit" />
      <text>工单列表</text>
    </view>
    <view class="action-btns flex-row">
      <view class="action-btn" bindtap="onRefresh">
        <image class="action-btn-icon" src="{{icons.refresh}}" mode="aspectFit" />
        <text>刷新</text>
      </view>
      <view class="action-btn" bindtap="toggleAutoRefresh">
        <image class="action-btn-icon" src="{{autoRefreshTimer ? icons.pause : icons.play}}" mode="aspectFit" />
        <text>{{autoRefreshTimer ? '暂停' : '自动'}}</text>
      </view>
    </view>
  </view>

  <!-- 工单列表 -->
  <view class="order-list container">
    <view class="order-card card" wx:for="{{orders}}" wx:key="order_id">
      <!-- SLA 超时标红 -->
      <view class="sla-warning-bar" wx:if="{{item.isSlaExceeded}}">
        <image class="icon-tiny" src="{{icons.warningRed}}" mode="aspectFit" />
        <text>SLA超时 - 超过2小时未接单</text>
      </view>
      
      <view class="order-header flex-between">
        <text class="order-title">{{item.title}}</text>
        <view class="tag" style="background:{{item.statusColor}}22;color:{{item.statusColor}}">{{item.statusText}}</view>
      </view>
      <text class="order-desc">{{item.description}}</text>
      <view class="order-meta flex-between mt-20">
        <text class="order-id">{{item.order_id}} | {{item.category}}</text>
        <text class="order-time">{{item.timeAgo}}</text>
      </view>
      
      <!-- 操作按钮 -->
      <view class="order-actions flex-row mt-20">
        <view class="action-btn primary" wx:if="{{item.status === 'submitted'}}" bindtap="onAcceptOrder" data-id="{{item.order_id}}">接单</view>
        <view class="action-btn outline" wx:if="{{item.status === 'submitted'}}" bindtap="onAssignOrder" data-id="{{item.order_id}}">派单</view>
        <view class="action-btn outline" bindtap="onOrderDetail" data-id="{{item.order_id}}">详情</view>
      </view>
    </view>
  </view>
</view>
