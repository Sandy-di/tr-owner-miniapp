/* pages/property/dashboard/dashboard.wxss - 物业看板 v3.0 · Stripe */
.page-property-dashboard {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: 40rpx;
}

.dashboard-header {
  position: relative;
}

.dashboard-bg {
  height: 240rpx;
  background: linear-gradient(155deg, var(--brand-dark) 0%, #2a2d7a 40%, #3d40a8 100%);
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  margin: -140rpx 24rpx 0;
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  padding: 32rpx 16rpx;
  box-shadow: var(--shadow-card-hover);
  border: 1rpx solid var(--border-light);
  position: relative;
  z-index: 1;
}

.stat-item {
  text-align: center;
}

.stat-num {
  font-size: 48rpx;
  font-weight: 300;
  display: block;
  line-height: 1.1;
  letter-spacing: -1rpx;
  font-variant-numeric: tabular-nums;
}

.stat-num.warning {
  color: var(--warning);
}

.stat-num.primary {
  color: var(--primary);
}

.stat-label {
  font-size: 22rpx;
  color: var(--body);
  display: block;
  margin-top: 8rpx;
  font-weight: 400;
}

/* SLA 警告 */
.sla-banner {
  display: flex;
  align-items: center;
  margin: 20rpx 24rpx 0;
  padding: 24rpx;
  background: rgba(234, 34, 97, 0.04);
  border: 1rpx solid rgba(234, 34, 97, 0.15);
  border-radius: var(--radius-sm);
  transition: all var(--transition-fast);
}

.sla-banner:active {
  background: rgba(234, 34, 97, 0.06);
}

.sla-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 14rpx;
  flex-shrink: 0;
}

.sla-text {
  flex: 1;
  font-size: 24rpx;
  color: var(--danger);
  font-weight: 400;
}

.sla-action {
  font-size: 24rpx;
  color: var(--primary);
  margin-left: 12rpx;
  font-weight: 500;
}

/* 操作栏 */
.action-bar {
  margin-top: 20rpx;
}

.action-btns {
  gap: 16rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  border-radius: var(--radius-xs);
  background: var(--bg-input);
  color: var(--body);
  font-weight: 400;
  border: 1rpx solid var(--border-color);
  transition: all var(--transition-fast);
}

.action-btn-icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 6rpx;
}

.action-btn:active {
  background: var(--bg-hover);
}

/* 工单 */
.order-list {

}

.sla-warning-bar {
  display: flex;
  align-items: center;
  padding: 14rpx 20rpx;
  background: rgba(234, 34, 97, 0.04);
  border-radius: var(--radius-xs);
  margin-bottom: 16rpx;
  font-size: 24rpx;
  color: var(--danger);
  font-weight: 400;
  border: 1rpx solid rgba(234, 34, 97, 0.1);
}

.order-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--heading);
  flex: 1;
  margin-right: 16rpx;
}

.order-desc {
  font-size: 24rpx;
  color: var(--body);
  margin-top: 10rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.5;
}

.order-meta {

}

.order-id {
  font-size: 22rpx;
  color: var(--body);
  font-variant-numeric: tabular-nums;
}

.order-time {
  font-size: 22rpx;
  color: var(--body);
  font-variant-numeric: tabular-nums;
}

.order-actions {
  gap: 16rpx;
}

.order-actions .action-btn {
  padding: 14rpx 32rpx;
  border-radius: var(--radius-xs);
  font-size: 24rpx;
  text-align: center;
  font-weight: 500;
}

.order-actions .action-btn.primary {
  background: var(--primary);
  color: #FFFFFF;
  border: none;
}

.order-actions .action-btn.outline {
  background: #FFFFFF;
  border: 2rpx solid var(--primary);
  color: var(--primary);
}
