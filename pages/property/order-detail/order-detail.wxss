/* pages/property/order-detail/order-detail.wxss - 物业工单详情 v3.0 · Stripe */
.page-order-detail {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: 60rpx;
}

.status-header {
  padding: 40rpx;
}

.status-badge {
  display: inline-flex;
  align-items: center;
  font-size: 26rpx;
  font-weight: 500;
  padding: 8rpx 24rpx;
  border-radius: var(--radius-full);
  margin-bottom: 20rpx;
}

.order-title {
  font-size: 34rpx;
  font-weight: 500;
  color: var(--heading);
  display: block;
  margin-bottom: 10rpx;
  letter-spacing: -0.3rpx;
}

.order-id {
  font-size: 24rpx;
  color: var(--body);
  font-variant-numeric: tabular-nums;
}

.owner-info {
  align-items: center;
}

.owner-avatar {
  width: 68rpx;
  height: 68rpx;
  border-radius: var(--radius-md);
  background: rgba(83, 58, 253, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  font-size: 26rpx;
  color: var(--primary);
  font-weight: 500;
}

.owner-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--heading);
  display: block;
}

.owner-phone {
  font-size: 24rpx;
  color: var(--body);
  display: block;
  margin-top: 4rpx;
  font-variant-numeric: tabular-nums;
}

.call-btn {
  display: flex;
  align-items: center;
  padding: 14rpx 28rpx;
  border: 2rpx solid var(--success);
  border-radius: var(--radius-sm);
  color: var(--success);
  font-size: 24rpx;
  font-weight: 500;
  transition: all var(--transition-fast);
}

.call-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 6rpx;
}

.call-btn:active {
  background: var(--success-bg);
}

.upload-section {
  margin-bottom: 24rpx;
}

.upload-label {
  font-size: 26rpx;
  color: var(--body);
  display: block;
  margin-bottom: 14rpx;
  font-weight: 400;
}

.upload-btn {
  display: inline-flex;
  align-items: center;
  padding: 18rpx 36rpx;
  background: var(--bg-input);
  border: 2rpx dashed var(--border-color);
  border-radius: var(--radius-sm);
  font-size: 28rpx;
  color: var(--body);
  font-weight: 400;
  transition: all var(--transition-fast);
}

.upload-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 8rpx;
  opacity: 0.5;
}

.upload-btn:active {
  border-color: var(--primary);
  background: var(--primary-bg);
  color: var(--primary);
}
