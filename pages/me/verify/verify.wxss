/* pages/me/verify/verify.wxss - 身份核验 v3.0 · Stripe */
.page-verify {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: 60rpx;
}

.current-level {
  padding: 48rpx;
}

.level-icon-img {
  width: 72rpx;
  height: 72rpx;
  display: block;
  margin: 0 auto 16rpx;
}

.level-current {
  font-size: 24rpx;
  color: var(--body);
  display: block;
  margin-bottom: 10rpx;
  font-weight: 400;
}

.level-value {
  font-size: 40rpx;
  font-weight: 300;
  color: var(--primary);
  display: block;
  margin-bottom: 24rpx;
  letter-spacing: -0.5rpx;
}

.level-progress {
  margin-top: 20rpx;
}

/* 等级卡片 */
.level-card {
  transition: all var(--transition-fast);
}

.level-card:active {
  transform: scale(0.992);
}

.level-header {
  align-items: center;
}

.level-icon-text {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.level-info {

}

.level-label {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--heading);
  display: block;
}

.level-desc {
  font-size: 22rpx;
  color: var(--body);
  display: block;
  margin-top: 6rpx;
}

.level-status {
  flex-shrink: 0;
}

.status-completed, .status-current, .status-locked {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  font-weight: 500;
}

.status-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 6rpx;
}

.status-completed {
  color: var(--success);
}

.status-current {
  color: var(--primary);
}

.status-locked {
  color: var(--text-disabled);
}

/* 核验表单 */
.verify-form {

}

.verify-tip {
  background: rgba(155, 104, 41, 0.04);
  border-radius: var(--radius-sm);
  padding: 18rpx 24rpx;
  margin-top: 20rpx;
  border: 1rpx solid rgba(155, 104, 41, 0.15);
  display: flex;
  align-items: flex-start;
}

.verify-tip text {
  font-size: 22rpx;
  color: var(--warning);
  line-height: 1.6;
}

/* 人脸核身 */
.face-verify {
  padding: 48rpx 0;
}

.face-icon {
  width: 88rpx;
  height: 88rpx;
  margin-bottom: 20rpx;
}

.face-desc {
  font-size: 28rpx;
  color: var(--heading);
  font-weight: 500;
  display: block;
  margin-bottom: 10rpx;
}

.face-tip {
  font-size: 24rpx;
  color: var(--body);
  display: block;
}

/* 说明 */
.explain-list {

}

.explain-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border-light);
}

.explain-item:last-child {
  border-bottom: none;
}

.explain-title {
  font-size: 26rpx;
  color: var(--heading);
  font-weight: 500;
  display: block;
  margin-bottom: 6rpx;
}

.explain-desc {
  font-size: 22rpx;
  color: var(--body);
  display: block;
  line-height: 1.5;
}
