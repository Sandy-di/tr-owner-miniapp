<!--pages/me/me.wxml-->
<view class="page-me">
  <!-- 用户信息 -->
  <view class="user-header">
    <view class="user-bg"></view>
    <view class="user-card">
      <view class="user-row flex-row">
        <view class="user-avatar">
          <text class="avatar-text">{{user.name[0] || '业'}}</text>
        </view>
        <view class="user-info flex-col flex-1">
          <text class="user-name">{{user.name}}</text>
          <text class="user-phone">{{user.phone}}</text>
          <view class="user-community">{{user.community}}</view>
        </view>
        <view class="verify-badge" bindtap="onUpgradeVerify">
          <view class="verify-dot" style="background: {{verifyColor}}"></view>
          <text class="verify-text" style="color: {{verifyColor}}">{{verifyText}}</text>
          <text class="verify-arrow" wx:if="{{user.verify_level < 4}}">升级 ›</text>
        </view>
      </view>
      <!-- 房产信息 -->
      <view class="property-info flex-between mt-20">
        <view class="property-item">
          <text class="property-value">{{user.building}}</text>
          <text class="property-label">房产</text>
        </view>
        <view class="property-divider"></view>
        <view class="property-item">
          <text class="property-value">{{user.area}}㎡</text>
          <text class="property-label">面积</text>
        </view>
        <view class="property-divider"></view>
        <view class="property-item">
          <text class="property-value">{{user.property_cert}}</text>
          <text class="property-label">认证状态</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 菜单列表 -->
  <view class="menu-list container">
    <view class="menu-card card">
      <view class="menu-item flex-row" 
        wx:for="{{menuList}}" wx:key="title"
        wx:if="{{!item.show || item.show === 'property'}}"
        bindtap="onMenuTap" data-url="{{item.url}}">
        <image class="menu-icon-img" src="{{icons[item.iconKey]}}" mode="aspectFit" />
        <text class="menu-title flex-1">{{item.title}}</text>
        <view class="menu-badge tag tag-primary" wx:if="{{item.badge}}">{{item.badge}}</view>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>
</view>
