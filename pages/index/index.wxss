/* pages/index/index.wxss - 首页 v3.0 · Stripe Design Language */
.page-index {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: 40rpx;
}

/* ==================== SVG 图标通用样式 ==================== */
.icon-inline {
  width: 28rpx;
  height: 28rpx;
  margin-right: 6rpx;
  vertical-align: middle;
}

.icon-tiny {
  width: 28rpx;
  height: 28rpx;
  margin-right: 8rpx;
  vertical-align: middle;
}

.icon-small {
  width: 36rpx;
  height: 36rpx;
}

.icon-medium {
  width: 44rpx;
  height: 44rpx;
}

.icon-large {
  width: 56rpx;
  height: 56rpx;
}

.stat-icon-img {
  width: 36rpx;
  height: 36rpx;
}

.action-icon-img {
  width: 40rpx;
  height: 40rpx;
}

.progress-label-row {
  display: flex;
  align-items: center;
}

/* ==================== 顶部区域 — Stripe 品牌深色 ==================== */
.header {
  position: relative;
  padding: 0 24rpx 60rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 400rpx;
  background: linear-gradient(155deg, var(--brand-dark) 0%, #2a2d7a 40%, #3d40a8 100%);
  border-radius: 0 0 var(--radius-xl) var(--radius-xl);
}

.header-content {
  position: relative;
  z-index: 1;
  padding-top: 48rpx;
}

.user-info {
  padding: 20rpx 0;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-lg);
  background: rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.15);
}

.avatar-text {
  font-size: 38rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.user-detail {
  flex: 1;
}

.user-name {
  font-size: 34rpx;
  color: #FFFFFF;
  font-weight: 500;
  margin-bottom: 8rpx;
  letter-spacing: -0.3rpx;
}

.verify-badge {
  align-items: center;
  background: rgba(255, 255, 255, 0.1);
  padding: 6rpx 16rpx;
  border-radius: var(--radius-full);
  align-self: flex-start;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
}

.verify-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  margin-right: 8rpx;
}

.verify-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  font-weight: 400;
}

.verify-arrow {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-left: 8rpx;
}

.community-badge {
  margin-top: 24rpx;
  display: inline-flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.08);
  padding: 10rpx 20rpx;
  border-radius: var(--radius-full);
  align-self: flex-start;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.community-badge .icon-inline {
  margin-right: 8rpx;
  filter: brightness(0) opacity(0.7);
}

.community-name {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 400;
}

/* ==================== 统计卡片 — Stripe 浮卡 ==================== */
.stats-row {
  padding: 0 24rpx;
  margin-top: -32rpx;
  position: relative;
  z-index: 2;
  gap: 16rpx;
}

.stat-card {
  flex: 1;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 28rpx 20rpx;
  text-align: center;
  box-shadow: var(--shadow-card-hover);
  border: 1rpx solid var(--border-light);
  transition: transform var(--transition-fast), box-shadow var(--transition-normal);
}

.stat-card:active {
  transform: scale(0.97);
  box-shadow: var(--shadow-card);
}

.stat-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border-radius: var(--radius-md);
  margin: 0 auto 12rpx;
}

.stat-icon-primary {
  background: rgba(83, 58, 253, 0.08);
}

.stat-icon-warning {
  background: rgba(155, 104, 41, 0.08);
}

.stat-icon-danger {
  background: rgba(234, 34, 97, 0.08);
}

.stat-num {
  font-size: 48rpx;
  font-weight: 300;
  display: block;
  line-height: 1.1;
  letter-spacing: -1rpx;
}

.stat-num-primary {
  color: var(--primary);
}

.stat-num-warning {
  color: var(--warning);
}

.stat-num-danger {
  color: var(--danger);
}

.stat-label {
  font-size: 22rpx;
  color: var(--body);
  margin-top: 8rpx;
  display: block;
  font-weight: 400;
}

/* ==================== 快捷操作 — Stripe 紧凑 ==================== */
.quick-actions {
  margin-top: 20rpx;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx 0;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 0;
  transition: transform var(--transition-fast);
}

.action-item:active {
  transform: scale(0.92);
}

.action-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 12rpx;
  transition: transform var(--transition-fast);
}

.action-title {
  font-size: 24rpx;
  color: var(--body);
  font-weight: 400;
}

/* ==================== 投票区域 — Stripe 紫色系 ==================== */
.vote-section {

}

.vote-card {
  background: rgba(83, 58, 253, 0.03);
  border-radius: var(--radius-md);
  padding: 28rpx;
  border: 1rpx solid var(--border-soft-purple);
  transition: all var(--transition-fast);
}

.vote-card:active {
  background: rgba(83, 58, 253, 0.06);
}

.vote-card-top {

}

.vote-title {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--heading);
  display: block;
  line-height: 1.5;
  letter-spacing: -0.2rpx;
}

.vote-tags {
  gap: 12rpx;
}

.vote-level-tag {

}

.vote-progress {
  
}

.progress-section {
  
}

.progress-row {
  margin-bottom: 8rpx;
}

.progress-label {
  font-size: 24rpx;
  color: var(--body);
  font-weight: 400;
}

.progress-value {
  font-size: 24rpx;
  color: var(--primary);
  font-weight: 500;
  font-variant-numeric: tabular-nums;
}

.vote-deadline {
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--border-light);
}

.deadline-text {
  font-size: 24rpx;
  color: var(--body);
  font-weight: 400;
}

.deadline-arrow {
  margin-left: auto;
  font-size: 24rpx;
  color: var(--primary);
  font-weight: 400;
}

/* ==================== 公告 — Stripe 精准间距 ==================== */
.announcement-list {

}

.announcement-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border-light);
}

.announcement-item:last-child {
  border-bottom: none;
}

.announcement-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.announcement-title {
  font-size: 28rpx;
  color: var(--heading);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 16rpx;
  line-height: 1.5;
  font-weight: 400;
}

.announcement-time {
  font-size: 22rpx;
  color: var(--body);
  flex-shrink: 0;
  font-variant-numeric: tabular-nums;
}

/* ==================== 链接 ==================== */
.link {
  font-size: 24rpx;
  color: var(--primary);
  font-weight: 400;
}

/* ==================== 工单 ==================== */
.order-list {

}

.order-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border-light);
}

.order-item:last-child {
  border-bottom: none;
}

.order-header {
  margin-bottom: 8rpx;
}

.order-title {
  font-size: 28rpx;
  color: var(--heading);
  font-weight: 500;
}

.order-meta {
  gap: 24rpx;
}

.order-id {
  font-size: 22rpx;
  color: var(--body);
  font-variant-numeric: tabular-nums;
}

.order-time {
  font-size: 22rpx;
  color: var(--body);
  font-variant-numeric: tabular-nums;
}
