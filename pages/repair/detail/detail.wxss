/* pages/repair/detail/detail.wxss - 报修详情 v3.0 · Stripe */
.page-repair-detail {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: 40rpx;
}

/* 状态头部 */
.status-header {
  text-align: center;
  padding: 40rpx 28rpx;
}

.status-badge {
  display: inline-flex;
  align-items: center;
  font-size: 26rpx;
  font-weight: 500;
  padding: 8rpx 24rpx;
  border-radius: var(--radius-full);
  margin-bottom: 20rpx;
}

.order-title {
  font-size: 34rpx;
  font-weight: 500;
  color: var(--heading);
  display: block;
  margin-bottom: 8rpx;
  letter-spacing: -0.3rpx;
}

.order-id {
  font-size: 24rpx;
  color: var(--body);
  font-variant-numeric: tabular-nums;
}

/* 步骤条 */
.steps {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
}

.step-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.step-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: var(--bg-input);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
  margin-bottom: 12rpx;
  transition: all var(--transition-normal);
}

.step-icon-img {
  width: 28rpx;
  height: 28rpx;
}

.step-completed .step-icon {
  background: var(--success-bg);
  box-shadow: 0 0 0 4rpx rgba(21, 190, 83, 0.08);
}

.step-active .step-icon {
  background: rgba(83, 58, 253, 0.06);
  box-shadow: 0 0 0 4rpx rgba(83, 58, 253, 0.08);
}

.step-line {
  position: absolute;
  top: 30rpx;
  left: 50%;
  width: 100%;
  height: 4rpx;
  background: var(--border-light);
  z-index: 0;
}

.step-completed .step-line {
  background: var(--success);
}

.step-label {
  font-size: 22rpx;
  color: var(--body);
  font-weight: 400;
}

.step-completed .step-label {
  color: var(--success-text);
  font-weight: 500;
}

.step-active .step-label {
  color: var(--primary);
  font-weight: 500;
}

/* 维修人员 */
.staff-info {
  align-items: center;
}

.staff-avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: var(--radius-md);
  background: rgba(83, 58, 253, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.staff-avatar-text {
  font-size: 32rpx;
  color: var(--primary);
  font-weight: 500;
}

.staff-detail {

}

.staff-name {
  font-size: 28rpx;
  color: var(--heading);
  font-weight: 500;
  display: block;
}

.staff-time {
  font-size: 22rpx;
  color: var(--body);
  display: block;
  margin-top: 4rpx;
}

.call-btn {
  display: flex;
  align-items: center;
  padding: 14rpx 28rpx;
  border: 2rpx solid var(--success);
  border-radius: var(--radius-sm);
  color: var(--success);
  font-size: 24rpx;
  font-weight: 500;
  transition: all var(--transition-fast);
}

.call-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 6rpx;
}

.call-btn:active {
  background: var(--success-bg);
}

/* 评价 */
.evaluate-desc {
  font-size: 26rpx;
  color: var(--body);
  line-height: 1.6;
}

.rating-display {
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.star-icon {
  width: 36rpx;
  height: 36rpx;
}

.rating-comment {
  font-size: 26rpx;
  color: var(--body);
  line-height: 1.6;
}

/* 评价弹窗 */
.star-rating {
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.star-btn {
  font-size: 60rpx;
  color: var(--border-color);
  transition: all 0.15s ease;
}

.star-active {
  color: #FFB800;
  transform: scale(1.1);
}

.rating-textarea {
  background: var(--bg-card);
  border-radius: var(--radius-sm);
  padding: 22rpx 24rpx;
  font-size: 28rpx;
  width: 100%;
  min-height: 180rpx;
  box-sizing: border-box;
  border: 2rpx solid var(--border-color);
}

.modal-btns {
  gap: 20rpx;
}
