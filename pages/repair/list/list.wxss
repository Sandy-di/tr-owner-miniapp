/* pages/repair/list/list.wxss - 报修列表 v3.0 · Stripe */
.page-repair-list {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: 40rpx;
}

.order-card {
  transition: transform var(--transition-fast), box-shadow var(--transition-normal);
}

.order-card:active {
  transform: scale(0.992);
  box-shadow: var(--shadow-card);
}

.order-title {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--heading);
  flex: 1;
  margin-right: 16rpx;
  letter-spacing: -0.2rpx;
}

.order-desc {
  font-size: 26rpx;
  color: var(--body);
  margin-top: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.6;
}

.order-footer {

}

.order-meta {
  gap: 20rpx;
}

.order-id {
  font-size: 22rpx;
  color: var(--body);
  font-variant-numeric: tabular-nums;
}

.order-category {
  font-size: 22rpx;
  color: var(--body);
}

.order-time {
  font-size: 22rpx;
  color: var(--body);
  font-variant-numeric: tabular-nums;
}

.sla-warning {
  margin-top: 16rpx;
  padding: 14rpx 20rpx;
  background: rgba(155, 104, 41, 0.04);
  border-radius: var(--radius-sm);
  border: 1rpx solid rgba(155, 104, 41, 0.15);
  font-size: 24rpx;
  color: var(--warning);
  font-weight: 400;
}
