<!--pages/repair/list/list.wxml-->
<view class="page-repair-list">
  <!-- Tab切换 -->
  <view class="tab-bar flex-row">
    <view class="tab-item {{currentTab === item.key ? 'tab-active' : ''}}" 
      wx:for="{{tabs}}" wx:key="key"
      bindtap="onTabChange" data-tab="{{item.key}}">
      <text>{{item.label}}</text>
    </view>
  </view>

  <!-- 工单列表 -->
  <view class="order-list container">
    <view class="order-card card" 
      wx:for="{{filteredOrders}}" wx:key="order_id"
      bindtap="onOrderTap" data-id="{{item.order_id}}">
      <view class="order-header flex-between">
        <text class="order-title">{{item.title}}</text>
        <view class="tag" style="background:{{item.statusColor}}22;color:{{item.statusColor}}">{{item.statusText}}</view>
      </view>
      <text class="order-desc">{{item.description}}</text>
      <view class="order-footer flex-between mt-20">
        <view class="order-meta flex-row">
          <text class="order-id">{{item.order_id}}</text>
          <text class="order-category">{{item.category}}</text>
        </view>
        <text class="order-time">{{item.timeAgo}}</text>
      </view>
      <!-- SLA超时提示 -->
      <view class="sla-warning" wx:if="{{item.status === 'submitted'}}">
        <text>⚠️ 工单待接单中</text>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{filteredOrders.length === 0}}">
      <text class="empty-icon">🔧</text>
      <text class="empty-text">暂无工单</text>
    </view>
  </view>

  <!-- 发起报修按钮 -->
  <view class="fab-btn" bindtap="onCreateRepair">
    <text>+</text>
  </view>
</view>
